diff --git a/build/linux.gcc.inc b/build/linux.gcc.inc
index 1acaab6..b53e1f1 100644
--- a/build/linux.gcc.inc
+++ b/build/linux.gcc.inc
@@ -57,6 +57,11 @@ ifneq (,$(shell $(CONLY) -dumpfullversion -dumpversion | egrep  "^([5-9]|1[0-9]
     WARNING_SUPPRESS += -Wno-sized-deallocation
 endif
 
+# gcc 13.0 and later treat -Wchanges-meaning as a hard error by default
+ifneq (,$(shell $(CONLY) -dumpfullversion -dumpversion | egrep  "^(1[3-9]|[2-9][0-9])"))
+    WARNING_SUPPRESS += -Wno-error=changes-meaning
+endif
+
 # gcc 6.0 and later have -flifetime-dse option that controls
 # elimination of stores done outside the object lifetime
 ifneq (,$(shell $(CONLY) -dumpfullversion -dumpversion | egrep  "^([6-9]|1[0-9])"))
